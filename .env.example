# Code Mentor — Environment Variables (local dev)
# Copy this file to `.env` and fill in the values. Never commit `.env`.

# ---- SQL Server ----
# Password must meet SQL Server complexity: >=8 chars, upper+lower+digit+symbol.
MSSQL_SA_PASSWORD=CodeMentor_Dev_123!

# ---- OpenAI (used by AI service; optional until Sprint 5) ----
# Get one at https://platform.openai.com/api-keys — but you don't need a real key
# until Sprint 5 when we wire up the AI review pipeline. A dummy value makes the
# AI service boot; real calls will fail without a real key.
OPENAI_API_KEY=openai-api-key-here...
# ---- Backend: JWT signing keys (Sprint 1, S1-T4) ----
# Paste RS256 private/public key pair (PEM content on single lines, escape newlines with \n).
# See docs/dev-keys.md for generation instructions.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ISSUER=CodeMentor
JWT_AUDIENCE=CodeMentor.Api
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# ---- Backend: GitHub OAuth (Sprint 1, S1-T7) ----
# Register an OAuth App at https://github.com/settings/applications/new
# Callback URL:  http://localhost:5000/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ---- Backend: OAuth token encryption key (Sprint 2, S2-T0a) ----
# 32-byte base64 key for AES-256-GCM token encryption. Generate with:
#   openssl rand -base64 32
# NOTE: appsettings.Development.json has a dev-only default — safe for local only.
OAUTH_TOKEN_ENCRYPTION_KEY=

# ---- Backend: connection strings ----
# Used by CodeMentor.Api through appsettings + env var overrides.
BACKEND__CONNECTIONSTRINGS__DEFAULT=Server=localhost,1433;Database=CodeMentor;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True;Encrypt=False
BACKEND__CONNECTIONSTRINGS__REDIS=localhost:6379
BACKEND__CONNECTIONSTRINGS__BLOB=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1;

# ---- Qdrant Vector DB (F12 Mentor Chat — Sprint 10, ADR-036) ----
# Used by the AI service for RAG retrieval over indexed code/feedback chunks.
# Inside docker-compose the AI service reaches Qdrant via the service hostname:
#   AI_ANALYSIS_QDRANT_URL=http://qdrant:6333  (default in compose)
# When the AI service runs on the host (via uvicorn) point it at localhost:
#   QDRANT_URL=http://localhost:6333
QDRANT_URL=http://localhost:6333

# ---- Frontend (used by Vite) ----
# Written to frontend/.env in S1-T12.
VITE_API_BASE_URL=http://localhost:5000
