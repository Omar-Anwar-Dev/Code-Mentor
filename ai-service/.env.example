# Environment Variables for AI Analysis Layer
# Copy this file to .env and fill in your values

# OpenAI Configuration (Required for AI review)
AI_ANALYSIS_OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model (default: gpt-5.1-codex-mini)
# AI_ANALYSIS_OPENAI_MODEL=gpt-5.1-codex-mini

# AI timeout in seconds (default: 180)
# AI_ANALYSIS_AI_TIMEOUT=180

# Max tokens for AI response (default: 8192) - use higher values for more detailed output
# AI_ANALYSIS_AI_MAX_TOKENS=8192

# Application Settings
# AI_ANALYSIS_DEBUG=false
# AI_ANALYSIS_LOG_LEVEL=INFO

# Server Settings
# AI_ANALYSIS_HOST=0.0.0.0
# AI_ANALYSIS_PORT=8001

# Analysis Settings
# AI_ANALYSIS_ANALYSIS_TIMEOUT=180
# AI_ANALYSIS_MAX_FILE_SIZE=1048576
# AI_ANALYSIS_MAX_FILES=50
